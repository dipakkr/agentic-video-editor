# ---- LLM ----
# Anthropic API key for the Editorial / Release agents.
# If unset, the Editorial Agent falls back to a deterministic, rule-based planner
# so the whole pipeline still runs end-to-end (graceful degradation).
ANTHROPIC_API_KEY=
AVE_LLM_MODEL=claude-sonnet-5
# Hard cap on LLM calls per project (cost control).
AVE_MAX_LLM_CALLS_PER_PROJECT=12

# ---- Storage ----
# "local" writes under AVE_DATA_DIR; "s3" uses the S3_* settings below.
AVE_STORAGE_BACKEND=local
AVE_DATA_DIR=./data
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=ave
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1

# ---- Datastores ----
DATABASE_URL=postgresql+psycopg://ave:ave@localhost:5432/ave
REDIS_URL=redis://localhost:6379/0

# ---- Media / analysis tuning ----
# Beat-snap tolerance window in milliseconds (a cut this far off-beat is snapped).
AVE_BEAT_SNAP_TOLERANCE_MS=180
# Mezzanine proxy resolution height for preview renders.
AVE_PROXY_HEIGHT=720
# Target integrated loudness for the web master (LUFS).
AVE_TARGET_LUFS=-14

# ---- Optional heavy dependencies ----
# Toggle expensive analysis passes. When off (or the lib is missing) the pipeline
# degrades gracefully instead of failing.
AVE_ENABLE_WHISPERX=false
AVE_ENABLE_SCENEDETECT=true
AVE_ENABLE_MEDIAPIPE=false
AVE_WHISPER_MODEL=base
